##axios baseUrl 一般情况无需单独配置,API接口地址配置成域名加接口地址即可
VUE_APP_API_ROOT=""
##项目域名，配置要求：
##线上环境及测试环境配置成域名
##本地开发则配置成localhost:8080、127.0.0.1:8080（根据浏览器访问地址配置：ip+端口号或者localhost+端口号）
VUE_APP_BASEURL="dat-m.my1000.cn"
##项目路由主目录地址
VUE_APP_BASE_PUBLIC_PATH="/h5/template"
##打包时使用无需更改
NODE_ENV="production"
#mock开关
VUE_APP_USE_MOCK=false
##vconsole开关，线上环境请关闭vconsole
VUE_APP_USE_VCONSOLE=true
#API接口地址 (格式：域名+接口地址) 各系统可以自行添加相应接口地址
VUE_APP_BASE_CUSTOMER="http://10.56.81.209:7081/customer-restful/restful/customer"
VUE_APP_BASE_WXWORK="http://10.56.112.51:8081/restful"
VUE_APP_BASE="https://dat-m.my1000.cn/h5"
VUE_APP_BASE_AI="https://dat-m.95549.cn"
##第三方appid 使用时请更改为相应系统的appid
VUE_APP_TD_APPID="61A27EBBEB8D4E51BB64414A71CF657C"
VUE_APP_WX_APPID="wx939194900c779a67"
VUE_APP_ALIPAY_APPID="2015090700258812"
##百度统计code,使用时请更改为相应系统的百度统计code
VUE_APP_BAIDU_TJ_CODE="df9f8bcf52713d7a98095e2f36117645"

##使用cdn优化加载,针对不同平台是否有cdn、cnd地址不同、是否使用cnd
VUE_APP_CDN="https://cdn-as.huaruisales.com"

##企业微信id,管理员账号登陆企业微信官网可获取
VUE_APP_WXWORK_APPID="wwa3c22f15328384dc"

##企业应用id,管理员账号登陆企业微信官网可获取
VUE_APP_WXWORK_AGENTID="1000002"

##企业微信ppf系统平台类型
VUE_APP_WXWORK_PPFTYPE=DAT_WXQYCBL


